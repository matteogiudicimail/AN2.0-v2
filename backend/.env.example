# CFS Reporting Backend — Environment variables example
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. [V1, V8]

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# BACKEND_PORT deve coincidere con PORT — usata dal proxy Angular dev-server
# (frontend/projects/mesa-ui/proxy.conf.js). Default: 3000.

# ─── SQL Server ───────────────────────────────────────────────────────────────
# Modalità Windows Authentication (processo Node gira sotto account Windows autorizzato)
DB_SERVER=localhost
DB_DATABASE=cfs_report
DB_WINDOWS_AUTH=true

# Fallback SQL Authentication (se DB_WINDOWS_AUTH=false)
# DB_USER=cfs_app_user
# DB_PASSWORD=replace-with-strong-password
# DB_ENCRYPT=false

# Pool options
# DB_POOL_MAX=10
# DB_POOL_MIN=0
# DB_POOL_IDLE_MS=30000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use the same secret/key configured in the MESAPPA host.
# Use JWT_SECRET for HMAC (HS256) or JWT_PUBLIC_KEY for RSA/EC (RS256/ES256).
JWT_SECRET=replace-with-your-secret-min-32-chars
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_ISSUER=mesappa-host
JWT_AUDIENCE=cfs-report

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins [V10]
CORS_ORIGINS=http://localhost:4201

# ─── MESAPPA Host ─────────────────────────────────────────────────────────────
# MESAPPA_HOST_URL=http://mesappa-server:8080
# MESAPPA_API_KEY=replace-with-mesappa-api-key

# ─── MESA Data Collection (Azure SQL) ─────────────────────────────────────────
# Database separato per le funzionalità MESA Data Collection.
# Lasciare MESA_DB_SERVER vuoto per disabilitare MESA all'avvio.
MESA_DB_SERVER=localhost
MESA_DB_DATABASE=mesa_dc
MESA_DB_WINDOWS_AUTH=true

# Fallback SQL Authentication (se MESA_DB_WINDOWS_AUTH=false)
# MESA_DB_USER=mesa_app_user
# MESA_DB_PASSWORD=replace-with-strong-password

# JWT per MESA (separato dal JWT MESAPPA host)
MESA_JWT_SECRET=replace-with-mesa-secret-min-32-chars
MESA_JWT_EXPIRES_IN=24h
