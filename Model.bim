          },
          {
            "type": "calculated",
            "name": "L_h05_C",
            "dataType": "string",
            "isDataTypeInferred": true,
            "isHidden": true,
            "expression": "LOOKUPVALUE([Folder_Code],[FolderChildKey],PATHITEM(Reclassification[PATH],5))"
          },
          {
            "type": "calculated",
            "name": "Account Father Code",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "var fc = Reclassification[Folder_Code] return SWITCH(TRUE(), ",
              "    Reclassification[L_h05_C]<>fc && Reclassification[L_h05] <> BLANK(), Reclassification[L_h05_C] ",
              "  , Reclassification[L_h04_C]<>fc && Reclassification[L_h04] <> BLANK(), Reclassification[L_h04_C]",
              "  , Reclassification[L_h03_C]<>fc && Reclassification[L_h03] <> BLANK(), Reclassification[L_h03_C]",
              "  , Reclassification[L_h02_C]<>fc && Reclassification[L_h02] <> BLANK(), Reclassification[L_h02_C]",
              "  , Reclassification[HierarchyMasterLever])"
            ]
          },
          {
            "type": "calculated",
            "name": "Folder Code",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": "var pr2 = PATHITEMREVERSE(Reclassification[PATH],1)  return IFERROR( right(pr2, len(pr2) - FIND(\"_\", pr2)), \"\")"
          }
        ],
