                "    dbo_tCFS_FactValue_Local = Source{[Schema=\"dbo\",Item=\"vCFS_FactValue_Local_Cube\"]}[Data],",
                "    #\"Removed Columns\" = Table.RemoveColumns(dbo_tCFS_FactValue_Local,{\"AdjIs\", \"TraceDate\", \"TraceUser\"})",
                "in",
                "    #\"Removed Columns\""
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Amount (Loc. Curr.)",
            "expression": "SUM('Fact'[Am Loc Sign])",
            "formatString": "#,0.00"
          },
          {
            "name": "Amount (Doc. Curr.)",
            "expression": "SUM('Fact'[Am Doc Sign])",
            "formatString": "#,0.00"
          },
          {
            "name": "Avg Exch Rate",
            "expression": " AVERAGE('Fact'[ExcRateLocal])",
            "formatString": "0.00000"
          },
          {
            "name": "Amount (Loc. Curr.) vs Previous Process",
            "expression": [
              "",
              "var pp = CALCULATE([Amount (Loc. Curr.)], FILTER(ALL(Process), Process[LoadId] = MAX('Fact'[RefLoadKey])))",
              "return ",
              " [Amount (Loc. Curr.)] -  pp"
            ],
            "formatString": "#,0.00"
          }
        ]
      },
      {
        "name": "Hierarchy Visulization",
        "calculationGroup": {
          "calculationItems": [
            {
              "name": "Ragged",
              "expression": [
                "SWITCH ( TRUE (), ",
                "ISINSCOPE(Reclassification[L_h02]) && ISBLANK ( SELECTEDVALUE ( Reclassification[L_h02] ) ), BLANK (), ",
                "ISINSCOPE(Reclassification[L_h03]) && ISBLANK ( SELECTEDVALUE ( Reclassification[L_h03] ) ), BLANK (), ",
                "ISINSCOPE(Reclassification[L_h04]) && ISBLANK ( SELECTEDVALUE ( Reclassification[L_h04] ) ), BLANK (), ",
                "ISINSCOPE(Reclassification[L_h05]) && ISBLANK ( SELECTEDVALUE ( Reclassification[L_h05] ) ), BLANK (),  SELECTEDMEASURE())",
                ""
              ],
              "ordinal": 1
            },
            {
              "name": "Flatted",
              "expression": "SELECTEDMEASURE()",
              "ordinal": 2
            }
          ]
