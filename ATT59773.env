# CFS Reporting Backend — configurazione locale sviluppo
# NON committare questo file. [V1, V8]

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── SQL Server (Azure SQL — SQL Auth) ────────────────────────────────────────
DB_SERVER=seaside.database.windows.net
DB_DATABASE=MESAFINANCEDEMO
DB_WINDOWS_AUTH=false
DB_USER=mesafinancedemobe
DB_PASSWORD=f8fyrnPgngEX21Nm6D
DB_ENCRYPT=true

# ─── Seed ─────────────────────────────────────────────────────────────────────
# Impostare a true quando le tabelle esistono già e non serve rieseguire il seed.
SKIP_SEED=true

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=mesa-dev-secret-change-in-production
JWT_ISSUER=
JWT_AUDIENCE=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200,http://localhost:7003

# ─── MESAPPA Host (Seaside menu) ──────────────────────────────────────────────
# Lasciare vuoto in dev — il servizio logga un warning e prosegue.
# MESAPPA_HOST_URL=http://mesappa-server:8080
# MESAPPA_API_KEY=
