{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/backend",
      "port": 3000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["ng", "serve", "mesa-ui", "--port", "4201"],
      "cwd": "${workspaceFolder}/frontend",
      "port": 4201
    }
  ]
}
