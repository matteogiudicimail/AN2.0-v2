{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"cfs-report-shell": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				}
			},
			"root": "projects/cfs-report-shell",
			"sourceRoot": "projects/cfs-report-shell/src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "ngx-build-plus:browser",
					"options": {
						"outputPath": "dist/cfs-report-shell",
						"index": "projects/cfs-report-shell/src/index.html",
						"main": "projects/cfs-report-shell/src/main.ts",
						"polyfills": ["zone.js"],
						"tsConfig": "projects/cfs-report-shell/tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/cfs-report-shell/src/favicon.ico",
							"projects/cfs-report-shell/src/assets"
						],
						"styles": [
							"node_modules/ag-grid-community/styles/ag-grid.css",
							"node_modules/ag-grid-community/styles/ag-theme-alpine.css",
							"projects/cfs-report-shell/src/styles.scss",
							"projects/cfs-report/src/lib/configurator/configurator.styles.scss"
						],
						"scripts": [],
						"extraWebpackConfig": "projects/cfs-report-shell/webpack.config.js",
						"commonChunk": false
					},
					"configurations": {
						"production": {
							"budgets": [
								{ "type": "initial", "maximumWarning": "500kb", "maximumError": "1mb" },
								{ "type": "anyComponentStyle", "maximumWarning": "6kb", "maximumError": "4kb" }
							],
							"outputHashing": "all",
							"extraWebpackConfig": "projects/cfs-report-shell/webpack.prod.config.js"
						},
						"development": {
							"buildOptimizer": false,
							"optimization": false,
							"vendorChunk": true,
							"extractLicenses": false,
							"sourceMap": true,
							"namedChunks": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "ngx-build-plus:dev-server",
					"configurations": {
						"production": {
							"browserTarget": "cfs-report-shell:build:production",
							"extraWebpackConfig": "projects/cfs-report-shell/webpack.prod.config.js"
						},
						"development": {
							"browserTarget": "cfs-report-shell:build:development"
						}
					},
					"defaultConfiguration": "development",
					"options": {
						"port": 4200,
						"publicHost": "http://localhost:4200",
						"extraWebpackConfig": "projects/cfs-report-shell/webpack.config.js",
						"proxyConfig": "proxy.conf.json"
					}
				},
				"extract-i18n": {
					"builder": "ngx-build-plus:extract-i18n",
					"options": {
						"browserTarget": "cfs-report-shell:build",
						"extraWebpackConfig": "projects/cfs-report-shell/webpack.config.js"
					}
				},
				"test": {
					"builder": "@angular-devkit/build-angular:karma",
					"options": {
						"polyfills": ["zone.js", "zone.js/testing"],
						"tsConfig": "projects/cfs-report-shell/tsconfig.spec.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/cfs-report-shell/src/favicon.ico",
							"projects/cfs-report-shell/src/assets"
						],
						"styles": [
							"node_modules/ag-grid-community/styles/ag-grid.css",
							"node_modules/ag-grid-community/styles/ag-theme-alpine.css",
							"projects/cfs-report-shell/src/styles.scss"
						],
						"scripts": []
					}
				}
			}
		},
		"mesa-ui": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": { "style": "scss" }
			},
			"root": "projects/mesa-ui",
			"sourceRoot": "projects/mesa-ui/src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular-devkit/build-angular:browser",
					"options": {
						"outputPath": "dist/mesa-ui",
						"index": "projects/mesa-ui/src/index.html",
						"main": "projects/mesa-ui/src/main.ts",
						"polyfills": ["zone.js"],
						"tsConfig": "projects/mesa-ui/tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/mesa-ui/src/favicon.ico",
							"projects/mesa-ui/src/assets"
						],
						"styles": [
							"node_modules/ag-grid-community/styles/ag-grid.css",
							"node_modules/ag-grid-community/styles/ag-theme-alpine.css",
							"projects/mesa-ui/src/styles.scss"
						],
						"scripts": []
					},
					"configurations": {
						"production": {
							"budgets": [
								{ "type": "initial", "maximumWarning": "1mb", "maximumError": "2mb" },
								{ "type": "anyComponentStyle", "maximumWarning": "6kb", "maximumError": "12kb" }
							],
							"outputHashing": "all"
						},
						"development": {
							"buildOptimizer": false,
							"optimization": false,
							"vendorChunk": true,
							"extractLicenses": false,
							"sourceMap": true,
							"namedChunks": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular-devkit/build-angular:dev-server",
					"configurations": {
						"production": { "browserTarget": "mesa-ui:build:production" },
						"development": { "browserTarget": "mesa-ui:build:development" }
					},
					"defaultConfiguration": "development",
					"options": {
						"port": 4201,
						"proxyConfig": "projects/mesa-ui/proxy.conf.json"
					}
				},
				"test": {
					"builder": "@angular-devkit/build-angular:karma",
					"options": {
						"polyfills": ["zone.js", "zone.js/testing"],
						"tsConfig": "projects/mesa-ui/tsconfig.spec.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/mesa-ui/src/favicon.ico",
							"projects/mesa-ui/src/assets"
						],
						"styles": ["projects/mesa-ui/src/styles.scss"],
						"scripts": []
					}
				}
			}
		}
	},
	"cli": {
		"analytics": false
	}
}
